{{ 'template-inspiration.css' | asset_url | stylesheet_tag }}

{% style %}

.inspiration-{{ section.id }}{
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: {{ section.settings.margin_top_mobile }}px;
  margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
}

.inspiration-{{ section.id }} > .page-width {
    padding: 0 1.5rem;
}

.inspiration__header{
  justify-content: {{ section.settings.heading_alignment }};
}

.inspiration__heading{
  text-align: {{ section.settings.heading_alignment }};
}

.inspiration__title{
  font-size: {{ section.settings.title_size_mobile }}px;
  line-height: {{ section.settings.title_line_mobile }}px;
}

.inspiration__text{
  font-size: {{ section.settings.text_size_mobile }}px;
  line-height: {{ section.settings.text_line_mobile }}px;
}

@media screen and (min-width: 990px){
  .inspiration-{{ section.id }}{
    margin-top: {{ section.settings.margin_top_desktop }}px;
    margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
  }

  .inspiration__title{
    font-size: {{ section.settings.title_size_desktop }}px;
    line-height: {{ section.settings.title_line_desktop }}px;
  }

  .inspiration__text{
    font-size: {{ section.settings.text_size_desktop }}px;
    line-height: {{ section.settings.text_line_desktop }}px;
  }
}

{% endstyle %}

<section class="inspiration inspiration-{{ section.id }}">
  <div class="inspiration__container page-width">
    {% if section.settings.heading != blank %}
      <div class="inspiration__header">
        <h2 class="inspiration__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      </div>
    {% endif %}

    <div class="inspiration__content">
      {% for block in section.blocks %}
        <div class="inspiration__block" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="inspiration__image">
              <img
                src="{{ block.settings.image | image_url: width: 291 }}"
                alt="{{ block.settings.title }}" width="291" height="{{ 291 | times: block.settings.image.height | divided_by: block.settings.image.width | round }}"
                class="{% if block.settings.aspect == 'portrait' %}inspiration__image--portrait{% elsif block.settings.aspect == 'landscape' %}inspiration__image--landscape{% endif %}"
                loading="lazy">
            </div>
          {% endif %}

          <div class="inspiration__info">
            {% if block.settings.title != blank %}
              <h3 class="inspiration__title">
                {{ block.settings.title }}
              </h3>
            {% endif %}

            {% if block.settings.text != blank %}
              <p class="inspiration__text">
                {{ block.settings.text }}
              </p>
            {% endif %}
          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Inspiration",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Change the look of your house, change the perspective of others"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "margin_top_mobile",
      "label": "Margin top mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom_mobile",
      "label": "Margin bottom mobile",
      "min": 0,
      "max": 200,
      "step": 4,
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top_desktop",
      "label": "Margin top desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 80
    },
    {
      "type": "range",
      "id": "margin_bottom_desktop",
      "label": "Margin bottom desktop",
      "min": 0,
      "max": 200,
      "step": 2,
      "default": 80
    },
    {
      "type": "header",
      "content": "Heading typography"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        },
        {
          "value": "h_custom",
          "label": "Custom Heading"
        }
      ],
      "default": "h_custom",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.collapsible_content.settings.heading_alignment.label",
      "options": [
        {
          "value": "left",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.collapsible_content.settings.heading_alignment.options__3.label"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Block title typography"
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title size mobile",
      "min": 14,
      "max": 40,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "title_line_mobile",
      "label": "Title line height mobile",
      "min": 16,
      "max": 60,
      "step": 2,
      "default": 30
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Title size desktop",
      "min": 16,
      "max": 50,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "title_line_desktop",
      "label": "Title line height desktop",
      "min": 20,
      "max": 70,
      "step": 2,
      "default": 38
    },
    {
      "type": "header",
      "content": "Text typography"
    },
    {
      "type": "range",
      "id": "text_size_mobile",
      "label": "Text size mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "text_line_mobile",
      "label": "Text line height mobile",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size_desktop",
      "label": "Text size desktop",
      "min": 12,
      "max": 28,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "text_line_desktop",
      "label": "Text line height desktop",
      "min": 16,
      "max": 40,
      "step": 2,
      "default": 26
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Inspiration block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "aspect",
          "label": "Image orientation",
          "options": [
            {
              "value": "portrait",
              "label": "Portrait"
            },
            {
              "value": "landscape",
              "label": "Landscape"
            }
          ],
          "default": "portrait"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Showroom"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Content",
          "default": "Experience design for living at our flagship showroom located in Boston’s South End."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inspiration",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}