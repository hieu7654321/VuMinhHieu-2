{% style %}
.service-{{ section.id }}{
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin: {{ section.settings.margin_mobile }}px 0;
    padding: 0 1.5rem;
}

.service-{{ section.id }} .service__container{
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: {{ section.settings.gap_mobile }}px;
    width: 100%;
}

.service-{{ section.id }} .service__box{
    width: 100%;
    display: flex;
    flex-direction: row;
    gap: {{ section.settings.item_gap_mobile }}px;
}

.service-{{ section.id }} .service__image img{
    width: {{ section.settings.icon_size_mobile }}px;
    height: {{ section.settings.icon_size_mobile }}px;
    object-fit: cover;
}

.service-{{ section.id }} .service__info{
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.service-{{ section.id }} .service__heading{
    font-size: {{ section.settings.heading_size_mobile }}px;
    line-height: {{ section.settings.heading_line_mobile }}px;
    font-weight:400;
    margin: 0;
    letter-spacing: 0;
}

.service-{{ section.id }} .service__content{
    font-size: {{ section.settings.text_size_mobile }}px;
    line-height: {{ section.settings.text_line_mobile }}px;
    letter-spacing: 0;
}

@media screen and (min-width:750px){
    .service-{{ section.id }}{
        margin: {{ section.settings.margin_desktop }}px auto;
    }

    .service-{{ section.id }} .service__container{
        justify-content: space-evenly;
        gap: {{ section.settings.gap_desktop }}px;
    }

    .service-{{ section.id }} .service__box{
        width: clamp(30rem ,{{ section.settings.item_width }}%, 45rem);
        flex-direction: column;
    }

    .service-{{ section.id }} .service__image img{
        width: {{ section.settings.icon_size_desktop }}px;
        height: {{ section.settings.icon_size_desktop }}px;
    }

    .service-{{ section.id }} .service__heading{
        font-size: {{ section.settings.heading_size_desktop }}px;
        line-height: {{ section.settings.heading_line_desktop }}px;
    }

    .service-{{ section.id }} .service__content{
        font-size: {{ section.settings.text_size_desktop }}px;
        line-height: {{ section.settings.text_line_desktop }}px;
    }
}

@media screen and (min-width:1024px){
    .service-{{ section.id }} .service__info{
        gap: 9px;
    }
}

@media screen and (min-width:1300px){
    .service-{{ section.id }} .service__container{
        justify-content: space-between;
    }

    .service-{{ section.id }} .service__box{
        width: 30.8rem;
        flex-direction: column;
    }
}

@media screen and (min-width:1500px){
    .service-{{ section.id }} {
        padding: 0;
    }
}
{% endstyle %}

<div class="service-{{ section.id }} page-width">
  <div class="service__container">
    {% for block in section.blocks %}
      <div class="service__box" {{ block.shopify_attributes }}>
        {% if block.settings.icon != blank %}
          <div class="service__image">
            {{ block.settings.icon | image_url: width: 200 | image_tag }}
          </div>
        {% endif %}

        <div class="service__info">
          {% if block.settings.heading != blank %}
            <h2 class="service__heading">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.text != blank %}
            <div class="service__content">
              {{ block.settings.text }}
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>
{% schema %}
