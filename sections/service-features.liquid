  "blocks":[
    {
      "type":"service",
      "name":"Service item",
      "settings":[
        {
          "type":"image_picker",
          "id":"icon",
          "label":"Icon"
        },
        {
          "type":"text",
          "id":"heading",
          "label":"Heading",
          "default":"Free & fast delivery"
        },
        {
          "type":"textarea",
          "id":"text",
          "label":"Text",
