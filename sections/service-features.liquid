      "default": 26
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop",
      "min": 12,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_line_desktop",
      "label": "Heading line height desktop",
      "min": 14,
      "max": 70,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Text Typography"
    },
    {
      "type": "range",
