<section id="sale-block-{{ section.id }}"
  class="sale-block color-{{ section.settings.color_scheme }} page-width">

  <div class="sale-block__container">
    {% for block in section.blocks %}
      <div class="sale-block__item" {{ block.shopify_attributes }}>

        {% case block.type %}

          {% when 'image_block' %}
            {% if block.settings.image != blank %}
              <div class="sale-block__image">
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.image.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.image.width }}"
                  height="{{ block.settings.image.height }}"
                >
              </div>
            {% endif %}

          {% when 'text_block' %}
            <div class="sale-block__content">
              <div class="sale-block__inner">

                {% if block.settings.label != blank %}
                  <div class="sale-block__label">
                    {{ block.settings.label }}
                  </div>
                {% endif %}

                {% if block.settings.heading != blank %}
                  <h3 class="sale-block__heading">
                    {{ block.settings.heading }}
                  </h3>
                {% endif %}

                {% if block.settings.subtext != blank %}
                  <div class="sale-block__subtext">
                    {{ block.settings.subtext }}
                  </div>
                {% endif %}

                {% if block.settings.button_label != blank %}
                  <a href="{{ block.settings.button_link }}"
                     class="sale-block__button button">
                    {{ block.settings.button_label }}
                  </a>
                {% endif %}

              </div>
            </div>

        {% endcase %}
      </div>
    {% endfor %}
  </div>
</section>

{% style %}

#sale-block-{{ section.id }} {
  margin-top: {{ section.settings.margin_top_mobile }}px;
  margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
  padding: 0 3.85vw;
}

#sale-block-{{ section.id }} .sale-block__container {
  display: flex;
  flex-wrap: wrap;
  gap: {{ section.settings.gap_mobile }}px;
  justify-content: center;
}

#sale-block-{{ section.id }} .sale-block__item {
  flex: 1 1 100%;
  max-width: 36rem;
}

#sale-block-{{ section.id }} .sale-block__image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

#sale-block-{{ section.id }} .sale-block__content {
  background: {{ section.settings.text_background }};
  color: {{ section.settings.text_color }};
  text-align: center;
  height: 100%;
  display: flex;
  aspect-ratio: 360 / 480;
}

#sale-block-{{ section.id }} .sale-block__inner {
  width: 100%;
  display: flex;
  flex-direction: column;
  letter-spacing: 0;
}

#sale-block-{{ section.id }} .sale-block__label {
  font-size: {{ section.settings.label_size_mobile }}px;
  text-transform: uppercase;
  font-weight: 500;
  margin-bottom: 12px;
  margin-top: 30px;
  letter-spacing: 0;
}

#sale-block-{{ section.id }} .sale-block__heading {
  font-size: {{ section.settings.heading_size_mobile }}px;
  line-height: {{ section.settings.heading_line_height_mobile }}px;
  font-weight: 400;
  max-width: 20rem;
  margin-inline: auto;
  letter-spacing: 0;
  margin-top: 7.4rem;
  margin-bottom: 0;
}

#sale-block-{{ section.id }} .sale-block__subtext {
  margin-top: 1rem;
  font-size: {{ section.settings.subtext_size_mobile }}px;
  max-width: 25rem;
  margin-inline: auto;
}

@media screen and (min-width: 750px) {
    #sale-block-{{ section.id }} .sale-block__item {
        max-width: clamp(22rem, 28.58vw, 42rem);
    }

    #sale-block-{{ section.id }} .sale-block__container {
        gap: 1.6rem;
    }

    #sale-block-{{ section.id }} .sale-block__label {
      font-size: clamp(1.2rem, 1.2vw, {{ section.settings.label_size_desktop }}px);
    }

    #sale-block-{{ section.id }} .sale-block__heading {
      font-size: clamp(3.6rem, 4vw, {{ section.settings.heading_size_desktop }}px);
      line-height: clamp(3.8rem, 5vw, {{ section.settings.heading_line_height_desktop }}px);
      margin-top: clamp(4rem, 5.2vw, 9.7rem);
      max-width: clamp(16rem, 18vw, 25rem);
    }

    #sale-block-{{ section.id }} .sale-block__subtext {
      font-size: clamp(1.2rem, 1.2vw, {{ section.settings.subtext_size_desktop }}px);
      max-width: clamp(22rem, 22vw, 25rem);
    }
}

@media screen and (min-width: 990px) {

  #sale-block-{{ section.id }} {
    margin-top: {{ section.settings.margin_top_desktop }}px;
    margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
  }

  #sale-block-{{ section.id }} .sale-block__container {
    gap: {{ section.settings.gap_desktop }}px;
    justify-content: space-between;
  }

  #sale-block-{{ section.id }} .sale-block__item {
    flex: 1 1 29.78%;
    max-width: 29.78%;
  }
}

@media screen and (min-width: 1500px) {
  #sale-block-{{ section.id }} {
    padding: 0;
  }
}
{% endstyle %}
{% schema %}
{
  "name": "Sale Block",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    { "type": "range", "id": "margin_top_mobile", "min": 0, "max": 200, "step": 4, "default": 40, "label": "Margin top (mobile)" },
    { "type": "range", "id": "margin_bottom_mobile", "min": 0, "max": 200, "step": 4, "default": 40, "label": "Margin bottom (mobile)" },
    { "type": "range", "id": "margin_top_desktop", "min": 0, "max": 300, "step": 4, "default": 80, "label": "Margin top (desktop)" },
    { "type": "range", "id": "margin_bottom_desktop", "min": 0, "max": 300, "step": 4, "default": 80, "label": "Margin bottom (desktop)" },

    { "type": "range", "id": "gap_mobile", "min": 0, "max": 60, "step": 2, "default": 16, "label": "Gap (mobile)" },
    { "type": "range", "id": "gap_desktop", "min": 0, "max": 100, "step": 4, "default": 32, "label": "Gap (desktop)" },

    {
      "type": "header",
      "content": "Typography"
    },
    { "type": "range", "id": "label_size_mobile", "min": 12, "max": 40, "step": 1, "default": 16, "label": "Label size (mobile)" },
    { "type": "range", "id": "label_size_desktop", "min": 12, "max": 60, "step": 1, "default": 18, "label": "Label size (desktop)" },

    { "type": "range", "id": "heading_size_mobile", "min": 18, "max": 80, "step": 2, "default": 36, "label": "Heading size (mobile)" },
    { "type": "range", "id": "heading_line_height_mobile", "min": 20, "max": 120, "step": 2, "default": 42, "label": "Heading line height (mobile)" },

    { "type": "range", "id": "heading_size_desktop", "min": 24, "max": 120, "step": 2, "default": 52, "label": "Heading size (desktop)" },
    { "type": "range", "id": "heading_line_height_desktop", "min": 30, "max": 160, "step": 2, "default": 60, "label": "Heading line height (desktop)" },

    { "type": "range", "id": "subtext_size_mobile", "min": 12, "max": 32, "step": 1, "default": 14, "label": "Subtext size (mobile)" },
    { "type": "range", "id": "subtext_size_desktop", "min": 12, "max": 40, "step": 1, "default": 16, "label": "Subtext size (desktop)" },

    {
      "type": "color",
      "id": "text_background",
      "label": "Text block background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "image_block",
      "name": "Image Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "text_block",
      "name": "Text Block",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "SEASON SALE COLLECTIONS" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "SALE 30% OFF" },
        { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Save extra on our sale collection\n*Runs until 14:00pm PST" },
        { "type": "text", "id": "button_label", "label": "Button label" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sale Block",
      "blocks": [
        { "type": "image_block" },
        { "type": "text_block" },
        { "type": "image_block" }
      ]
    }
  ]
}
{% endschema %}